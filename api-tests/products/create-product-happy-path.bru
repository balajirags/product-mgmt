meta {
  name: Create Product - Happy Path
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/products
  body: json
  auth: none
}

body:json {
  {
    "title": "Bruno Test Widget",
    "description": "A test product created by Bruno",
    "subtitle": "E2E test",
    "status": "DRAFT",
    "weight": 2.5,
    "height": 10.0,
    "width": 5.0,
    "length": 3.0,
    "metadata": {"source": "bruno-e2e"},
    "thumbnail": "https://example.com/thumb.jpg",
    "images": [
      {"url": "https://example.com/img1.jpg"},
      {"url": "https://example.com/img2.jpg"}
    ]
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.title: eq Bruno Test Widget
  res.body.handle: eq bruno-test-widget
  res.body.status: eq DRAFT
  res.body.description: eq A test product created by Bruno
  res.body.subtitle: eq E2E test
  res.body.is_giftcard: eq false
  res.body.discountable: eq true
  res.body.thumbnail: eq https://example.com/thumb.jpg
  res.body.created_at: isDefined
  res.body.updated_at: isDefined
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should have a valid UUID id", function() {
    const body = res.getBody();
    expect(body.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/);
  });

  test("should auto-generate handle from title", function() {
    const body = res.getBody();
    expect(body.handle).to.equal("bruno-test-widget");
  });

  test("should return thumbnail", function() {
    const body = res.getBody();
    expect(body.thumbnail).to.equal("https://example.com/thumb.jpg");
  });

  test("should return gallery images with rank ordering", function() {
    const body = res.getBody();
    expect(body.images).to.be.an("array").with.lengthOf(2);
    expect(body.images[0].url).to.equal("https://example.com/img1.jpg");
    expect(body.images[0].rank).to.equal(0);
    expect(body.images[1].url).to.equal("https://example.com/img2.jpg");
    expect(body.images[1].rank).to.equal(1);
  });

  test("should return dimensions", function() {
    const body = res.getBody();
    expect(body.weight).to.equal(2.5);
    expect(body.height).to.equal(10.0);
    expect(body.width).to.equal(5.0);
    expect(body.length).to.equal(3.0);
  });

  test("should return metadata", function() {
    const body = res.getBody();
    expect(body.metadata).to.deep.equal({source: "bruno-e2e"});
  });
}
