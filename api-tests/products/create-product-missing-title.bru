meta {
  name: Create Product - Missing Title (400)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/products
  body: json
  auth: none
}

body:json {
  {
    "handle": "no-title-product"
  }
}

assert {
  res.status: eq 400
  res.body.error_code: eq VALIDATION_ERROR
}

tests {
  test("should return 400 Bad Request", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should return VALIDATION_ERROR", function() {
    expect(res.getBody().error_code).to.equal("VALIDATION_ERROR");
  });
}
