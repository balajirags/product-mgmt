meta {
  name: CRUD Flow - Step 1 - Create Product
  type: http
  seq: 20
}

post {
  url: {{baseUrl}}/api/v1/products
  body: json
  auth: none
}

body:json {
  {
    "title": "CRUD Flow Product",
    "description": "Product for full CRUD lifecycle test",
    "thumbnail": "https://example.com/thumb.jpg",
    "images": [
      {"url": "https://example.com/flow-img1.jpg"},
      {"url": "https://example.com/flow-img2.jpg"}
    ]
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.title: eq CRUD Flow Product
}

tests {
  test("should create product and capture ID", function() {
    expect(res.getStatus()).to.equal(201);
    const body = res.getBody();
    expect(body.id).to.be.a("string");
    bru.setVar("productId", body.id);
  });
}
