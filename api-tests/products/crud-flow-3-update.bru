meta {
  name: CRUD Flow - Step 3 - Update Product
  type: http
  seq: 22
}

post {
  url: {{baseUrl}}/api/v1/products/{{productId}}
  body: json
  auth: none
}

body:json {
  {
    "title": "Updated CRUD Product",
    "description": "Updated description",
    "status": "PUBLISHED",
    "thumbnail": "https://example.com/new-thumb.jpg",
    "images": [
      {"url": "https://example.com/updated-img1.jpg"},
      {"url": "https://example.com/updated-img2.jpg"},
      {"url": "https://example.com/updated-img3.jpg"}
    ]
  }
}

assert {
  res.status: eq 200
  res.body.title: eq Updated CRUD Product
  res.body.status: eq PUBLISHED
  res.body.thumbnail: eq https://example.com/new-thumb.jpg
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should update title and status", function() {
    const body = res.getBody();
    expect(body.title).to.equal("Updated CRUD Product");
    expect(body.description).to.equal("Updated description");
    expect(body.status).to.equal("PUBLISHED");
  });

  test("should replace images with new set", function() {
    const body = res.getBody();
    expect(body.images).to.be.an("array").with.lengthOf(3);
    expect(body.images[0].url).to.equal("https://example.com/updated-img1.jpg");
    expect(body.images[2].url).to.equal("https://example.com/updated-img3.jpg");
    expect(body.images[0].rank).to.equal(0);
    expect(body.images[1].rank).to.equal(1);
    expect(body.images[2].rank).to.equal(2);
  });

  test("should update thumbnail", function() {
    const body = res.getBody();
    expect(body.thumbnail).to.equal("https://example.com/new-thumb.jpg");
  });
}
