meta {
  name: Delete Product - Not Found (404)
  type: http
  seq: 14
}

delete {
  url: {{baseUrl}}/api/v1/products/00000000-0000-0000-0000-000000000000
  body: none
  auth: none
}

assert {
  res.status: eq 404
  res.body.error_code: eq RESOURCE_NOT_FOUND
}

tests {
  test("should return 404 for non-existent product", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("should return RESOURCE_NOT_FOUND error", function() {
    expect(res.getBody().error_code).to.equal("RESOURCE_NOT_FOUND");
  });
}
