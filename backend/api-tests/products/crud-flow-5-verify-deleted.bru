meta {
  name: CRUD Flow - Step 5 - Verify Deleted (404)
  type: http
  seq: 24
}

get {
  url: {{baseUrl}}/api/v1/products/{{productId}}
  body: none
  auth: none
}

assert {
  res.status: eq 404
  res.body.error_code: eq RESOURCE_NOT_FOUND
}

tests {
  test("should return 404 for deleted product", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("should confirm product is soft-deleted", function() {
    expect(res.getBody().error_code).to.equal("RESOURCE_NOT_FOUND");
  });
}
