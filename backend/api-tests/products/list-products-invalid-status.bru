meta {
  name: List Products - Invalid Status Filter (409)
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/api/v1/products?status=INVALID
  body: none
  auth: none
}

assert {
  res.status: eq 409
  res.body.error_code: eq INVALID_STATUS
}

tests {
  test("should return 409 for invalid status filter", function() {
    expect(res.getStatus()).to.equal(409);
  });

  test("should return INVALID_STATUS error", function() {
    expect(res.getBody().error_code).to.equal("INVALID_STATUS");
  });
}
